{
  "title": "reset_legendary_birds_(platinum)",
  "description": "Optimisation of the previous code, fixes unrelated flag actions and provides better support for only respawning one bird at a time.",
  "author": "TimoVM",
  "supported": [
    "platinum"
  ],
  "scripts": [
    {
      "color": [
        180,
        180,
        180
      ],
      "title": "Re-Spawn Legendary Birds (Platinum)",
      "documentation": "This code marks all three legendary birds as respawnable. Talking to Prof. Oak in Eterna City will then cause them to roam the map once again.\n\nThe first command marks Moltres as respawnable, while the second and third commands do so for Zapdos and Articuno respectively. The final command resets the flag that indicates that all three birds have been caught already.\n\nIf you only want to respawn a specific bird, simply remove the LoadWkValue commands that reset the other birds.",
      "variables": [
        {
          "name": "FLAG_CAUGHT_ROAMING_LEGENDARY_BIRDS",
          "default": "152",
          "overrulingValues": {
            "ENG": "",
            "SP": "",
            "GER": "",
            "FR": "",
            "IT": "",
            "KOR": "",
            "JP5": "",
            "JP6": ""
          }
        },
        {
          "name": "VAR_ROAMING_MOLTRES_STATE",
          "default": "94",
          "overrulingValues": {
            "ENG": "",
