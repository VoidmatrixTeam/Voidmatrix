            "GER": "",
            "FR": "",
            "IT": "",
            "KOR": "",
            "JP5": "",
            "JP6": ""
          }
        },
        {
          "name": "VAR_ROAMING_ZAPDOS_STATE",
          "default": "95",
          "overrulingValues": {
            "ENG": "",
            "SP": "",
            "GER": "",
            "FR": "",
            "IT": "",
            "KOR": "",
            "JP5": "",
            "JP6": ""
          }
        },
        {
